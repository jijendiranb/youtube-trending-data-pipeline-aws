{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "S3FullAccess",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:ListBucket",
				"s3:DeleteObject"
			],
			"Resource": [
				"arn:aws:s3:::yt-data-bronze-layer",
				"arn:aws:s3:::yt-data-bronze-layer/*",
				"arn:aws:s3:::yt-data-silver-layer",
				"arn:aws:s3:::yt-data-silver-layer/*",
				"arn:aws:s3:::yt-data-gold-layer",
				"arn:aws:s3:::yt-data-gold-layer/*",
				"arn:aws:s3:::yt-data-scripts-list",
				"arn:aws:s3:::yt-data-scripts-list/*"
			]
		}
	]
}